{
  "name": "trinity-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @trinity/app-portal",
    "dev:poll": "VITE_WATCH_POLL=1 npm run dev -w @trinity/app-portal",
    "dev:trinity-ai": "npm run dev -w @trinity/app-trinity-ai",
    "dev:trinity-ai:poll": "VITE_WATCH_POLL=1 npm run dev -w @trinity/app-trinity-ai",
    "dev:ai-cloud": "npm run dev -w @trinity/app-ai-cloud",
    "dev:trinity-geo": "npm run dev -w @trinity/app-trinity-geo",
    "dev:trinity-ai-admin": "npm run dev -w @trinity/app-trinity-ai-admin",
    "dev:trinity-design": "npm run dev -w @trinity/app-trinity-design",
    "dev:ui-standalone-demo": "npm run dev -w @trinity/app-ui-standalone-demo",
    "dev:trinity-docs": "npm run dev -w @trinity/app-trinity-docs",
    "dev:trinity-product": "npm run dev -w @trinity/app-trinity-product",
    "build:trinity-docs": "npm run build -w @trinity/app-trinity-docs",
    "build:trinity-product": "npm run build -w @trinity/app-trinity-product",
    "build:apps": "npm run build -w @trinity/app-portal && npm run build -w @trinity/app-trinity-ai && npm run build -w @trinity/app-ai-cloud && npm run build -w @trinity/app-trinity-geo && npm run build -w @trinity/app-trinity-ai-admin && npm run build -w @trinity/app-trinity-design",
    "build:all": "npm run build:apps",
    "sync:web": "node scripts/sync-to-trinityai-web.mjs",
    "sync:web:apply": "node scripts/sync-to-trinityai-web.mjs --apply",
    "sync:web:apps": "node scripts/sync-to-trinityai-web.mjs --apps --apply",
    "sync:web:packages": "node scripts/sync-to-trinityai-web.mjs --packages --apply",
    "pricing:fetch": "node pricing/pipeline/fetch-online-prices.mjs --json-only",
    "pricing:fetch:all": "node pricing/pipeline/fetch-online-prices.mjs",
    "pricing:upstream": "node pricing/pipeline/gen-upstream-pricing.mjs",
    "pricing:upstream:image": "node pricing/pipeline/gen-upstream-image-pricing.mjs",
    "pricing:upstream:video": "node pricing/pipeline/gen-upstream-video-pricing.mjs",
    "pricing:refresh": "node pricing/pipeline/refresh-pricing-output.mjs",
    "pricing:gen-725": "node pricing/pipeline/gen-725-prices-api.mjs",
    "pricing:gen-65": "node pricing/pipeline/gen-725-prices-api.mjs --fx 6.5 --tag 0.65_prices --out draft/0.65_prices-api.json --optimized-065",
    "pricing:gen-65-official": "node pricing/pipeline/gen-official-065-prices-api.mjs",
    "pricing:gen-official:image": "node pricing/pipeline/gen-official-image-prices-api.mjs",
    "pricing:gen-official:video": "node pricing/pipeline/gen-official-video-prices-api.mjs",
    "pricing:diff:official-image": "node pricing/pipeline/diff-official-image-prices-api.mjs",
    "pricing:diff:official-video": "node pricing/pipeline/diff-official-video-prices-api.mjs",
    "pricing:publish-official:video": "node pricing/pipeline/publish-official-video-prices-api.mjs",
    "pricing:publish-official:image": "node pricing/pipeline/publish-official-image-prices-api.mjs",
    "pricing:rollout:video": "node pricing/pipeline/rollout-official-video-prices-api.mjs",
    "pricing:clean": "node pricing/pipeline/clean-pricing-output.mjs",
    "pricing:diff": "node pricing/pipeline/compare-online-vs-scraped.mjs",
    "pricing:diff:065": "node pricing/pipeline/compare-online-vs-scraped.mjs --scraped draft/0.65_prices-api.json",
    "pricing:validate": "node pricing/pipeline/validate-online-pricing.mjs",
    "pricing:compare:official": "node pricing/pipeline/compare-official-pricing.mjs",
    "pricing:compare:openrouter": "node pricing/pipeline/compare-openrouter-pricing.mjs",
    "pricing:validate:compare": "node pricing/pipeline/validate-pricing-compare.mjs",
    "pricing:validate:aigc-excel": "node pricing/pipeline/validate-aigc-excel.mjs",
    "pricing:validate:official-aigc": "node pricing/pipeline/validate-official-aigc.mjs",
    "pricing:validate:official-aigc-image": "node pricing/pipeline/validate-official-aigc-image.mjs",
    "pricing:validate:official-aigc-video": "node pricing/pipeline/validate-official-aigc-video.mjs",
    "pricing:validate:official-suppliers": "node pricing/pipeline/validate-official-vs-suppliers.mjs",
    "pricing:validate:official-suppliers-image": "node pricing/pipeline/validate-official-vs-suppliers-image.mjs",
    "pricing:validate:official-suppliers-video": "node pricing/pipeline/validate-official-vs-suppliers-video.mjs",
    "pricing:alert": "node pricing/pipeline/emit-pricing-alerts.mjs",
    "pricing:gate": "node pricing/pipeline/validate-pricing-gate.mjs",
    "pricing:supplier:openrouter": "node pricing/suppliers/openrouter/fetch-models.mjs",
    "pricing:supplier:tokenhub:console": "node pricing/suppliers/tokenhub/scrape-pricing.mjs && node pricing/suppliers/tokenhub/gen-sample.mjs",
    "pricing:supplier:tokenhub:sample": "node pricing/suppliers/tokenhub/gen-sample.mjs",
    "pricing:supplier:bailian:doc": "node pricing/suppliers/bailian/scrape-pricing.mjs",
    "pricing:supplier:bailian:normalize": "node pricing/suppliers/bailian/normalize-pricing.mjs",
    "pricing:supplier:bailian:sample": "node pricing/suppliers/bailian/gen-sample.mjs",
    "pricing:supplier:aigc": "node pricing/suppliers/aigc/build-pricing.mjs",
    "pricing:supplier:aigc:image": "node pricing/suppliers/aigc/build-pricing-image.mjs",
    "pricing:supplier:aigc:video": "node pricing/suppliers/aigc/build-pricing-video.mjs",
    "pricing:supplier:volcengine:doc": "node pricing/suppliers/volcengine/scrape-pricing.mjs",
    "pricing:supplier:volcengine": "node pricing/suppliers/volcengine/build-pricing.mjs",
    "pricing:supplier:volcengine:all": "npm run pricing:supplier:volcengine:doc && npm run pricing:supplier:volcengine",
    "pricing:supplier:wangju-cloudportal": "node pricing/suppliers/official-direct/build-pricing.mjs --channel=wangju-cloudportal",
    "pricing:supplier:relay-cust": "node pricing/suppliers/official-direct/build-pricing.mjs --channel=relay-cust",
    "pricing:supplier:official-direct:all": "node pricing/suppliers/official-direct/build-pricing.mjs --all",
    "pricing:supplier:official": "node pricing/suppliers/official/fetch-pricing.mjs --modality=text && node pricing/suppliers/official/gen-table.mjs --modality=text",
    "pricing:supplier:official:text": "node pricing/suppliers/official/fetch-pricing.mjs --modality=text && node pricing/suppliers/official/gen-table.mjs --modality=text",
    "pricing:supplier:official:image": "node pricing/suppliers/official/fetch-pricing.mjs --modality=image && node pricing/suppliers/official/gen-table.mjs --modality=image",
    "pricing:supplier:official:video": "node pricing/suppliers/official/fetch-pricing.mjs --modality=video && node pricing/suppliers/official/gen-table.mjs --modality=video",
    "pricing:supplier:official:all": "node pricing/suppliers/official/fetch-pricing.mjs --modality=all && node pricing/suppliers/official/gen-table.mjs --modality=all",
    "pricing:supplier:official:table": "node pricing/suppliers/official/gen-table.mjs --modality=text",
    "tokenhub:pricing:console": "npm run pricing:supplier:tokenhub:console",
    "tokenhub:pricing:sample": "npm run pricing:supplier:tokenhub:sample",
    "bailian:pricing:doc": "npm run pricing:supplier:bailian:doc",
    "bailian:pricing:normalize": "npm run pricing:supplier:bailian:normalize",
    "bailian:pricing:sample": "npm run pricing:supplier:bailian:sample",
    "compare:gen-725-prices": "npm run pricing:gen-725",
    "compare:gen-65-prices": "npm run pricing:gen-65",
    "compare:diff-prices": "npm run pricing:diff",
    "compare:diff-prices:065": "npm run pricing:diff:065",
    "compare:fetch-prices": "npm run pricing:fetch",
    "compare:fetch-prices:all": "npm run pricing:fetch:all",
    "compare:pricing": "npm run pricing:upstream",
    "compare:validate": "npm run pricing:validate",
    "aigc:pricing": "npm run pricing:supplier:aigc",
    "skill:lint:tools": "node scripts/lint-skill-tools.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "xlsx": "^0.18.5"
  }
}
