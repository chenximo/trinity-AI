{
  "name": "trinity-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @trinity/app-portal",
    "dev:poll": "VITE_WATCH_POLL=1 npm run dev -w @trinity/app-portal",
    "dev:trinity-ai": "npm run dev -w @trinity/app-trinity-ai",
    "dev:trinity-ai:poll": "VITE_WATCH_POLL=1 npm run dev -w @trinity/app-trinity-ai",
    "dev:ai-cloud": "npm run dev -w @trinity/app-ai-cloud",
    "dev:trinity-geo": "npm run dev -w @trinity/app-trinity-geo",
    "dev:trinity-ai-admin": "npm run dev -w @trinity/app-trinity-ai-admin",
    "dev:trinity-design": "npm run dev -w @trinity/app-trinity-design",
    "dev:ui-standalone-demo": "npm run dev -w @trinity/app-ui-standalone-demo",
    "dev:trinity-docs": "npm run dev -w @trinity/app-trinity-docs",
    "dev:trinity-product": "npm run dev -w @trinity/app-trinity-product",
    "build:trinity-docs": "npm run build -w @trinity/app-trinity-docs",
    "build:trinity-product": "npm run build -w @trinity/app-trinity-product",
    "build:apps": "npm run build -w @trinity/app-portal && npm run build -w @trinity/app-trinity-ai && npm run build -w @trinity/app-ai-cloud && npm run build -w @trinity/app-trinity-geo && npm run build -w @trinity/app-trinity-ai-admin && npm run build -w @trinity/app-trinity-design",
    "build:all": "npm run build:apps",
    "sync:web": "node scripts/sync-to-trinityai-web.mjs",
    "sync:web:apply": "node scripts/sync-to-trinityai-web.mjs --apply",
    "sync:web:apps": "node scripts/sync-to-trinityai-web.mjs --apps --apply",
    "sync:web:packages": "node scripts/sync-to-trinityai-web.mjs --packages --apply"
  }
}
