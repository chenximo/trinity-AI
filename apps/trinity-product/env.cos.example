# 复制为 apps/trinity-product/.env.local（已在仓库 .gitignore，勿提交密钥）
# 开发编辑页粘贴/拖拽图片时，由本地 Vite 中间件上传到 COS 并插入 Markdown 链接
#
# 若已配置 apps/trinity-docs/.env.local（TRINITY_DOCS_COS_*），可不建本文件，会自动复用凭证，
# 图片前缀仍为 trinity-product-ling/images/

TRINITY_PRODUCT_COS_SECRET_ID=your_secret_id
TRINITY_PRODUCT_COS_SECRET_KEY=your_secret_key
TRINITY_PRODUCT_COS_BUCKET=your-bucket-1250000000
TRINITY_PRODUCT_COS_REGION=ap-guangzhou

# 对象键前缀（可选，默认 trinity-product-ling/images/）
# TRINITY_PRODUCT_COS_PREFIX=trinity-product-ling/images/

# 对外访问域名（可选；不填则用 https://{bucket}.cos.{region}.myqcloud.com/{key}）
# TRINITY_PRODUCT_COS_PUBLIC_BASE=https://cdn.example.com
