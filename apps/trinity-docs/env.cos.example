# 复制为 apps/trinity-docs/.env.local（已在仓库 .gitignore，勿提交密钥）
# 开发编辑页粘贴图片时，由本地 Vite 中间件上传到 COS 并插入 Markdown 链接

TRINITY_DOCS_COS_SECRET_ID=your_secret_id
TRINITY_DOCS_COS_SECRET_KEY=your_secret_key
TRINITY_DOCS_COS_BUCKET=your-bucket-1250000000
TRINITY_DOCS_COS_REGION=ap-guangzhou

# 对象键前缀（可选，默认 trinity-docs/images/，其下直接放图片文件，无日期目录）
# TRINITY_DOCS_COS_PREFIX=trinity-docs/images/

# 对外访问域名（可选；不填则用 https://{bucket}.cos.{region}.myqcloud.com/{key}）
# TRINITY_DOCS_COS_PUBLIC_BASE=https://cdn.example.com
