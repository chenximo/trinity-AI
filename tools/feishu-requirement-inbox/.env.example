# 飞书应用
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# 事件加密（飞书后台开启加密时必填）
FEISHU_ENCRYPT_KEY=
# 允许的群 chat_id，逗号分隔；留空则不限制（仅建议开发环境）
FEISHU_ALLOWED_CHAT_IDS=

# 飞书多维表格「需求收件箱」
BITABLE_APP_TOKEN=
BITABLE_TABLE_ID=

# Trinity LLM（OpenAI 兼容）
TRINITY_BASE_URL=https://api.trinitydesk.ai/v1
TRINITY_API_KEY=
LLM_MODEL=deepseek-v3

# 消息窗口
MESSAGE_LIMIT=50
MESSAGE_WINDOW_HOURS=2

# 服务
HOST=0.0.0.0
PORT=8787
LOG_LEVEL=INFO

# 开发：dry-run 接口鉴权（生产可留空以禁用）
INTERNAL_DRY_RUN_TOKEN=dev-only-change-me
