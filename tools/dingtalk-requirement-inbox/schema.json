{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RequirementInboxExtraction",
  "type": "object",
  "required": ["session_summary", "candidates"],
  "properties": {
    "session_summary": {
      "type": "string",
      "minLength": 1
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "title",
          "summary",
          "module_suggestion",
          "reporter",
          "has_screenshot",
          "message_link",
          "confidence"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["bug", "feature", "doc", "question", "noise"]
          },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 },
          "module_suggestion": { "type": "string" },
          "reporter": { "type": "string" },
          "has_screenshot": { "type": "boolean" },
          "message_link": { "type": "string" },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        },
        "additionalProperties": false
      }
    },
    "ignored_reason": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
