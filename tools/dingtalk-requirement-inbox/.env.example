# 钉钉应用（开发者后台 → 凭证）
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# 仅允许这些群 conversationId，逗号分隔；留空则不限制
DINGTALK_ALLOWED_CONVERSATION_IDS=

# 钉钉多维表「需求收件箱」
NOTABLE_BASE_ID=
NOTABLE_SHEET_ID=
NOTABLE_SHEET_NAME=
# 可选；留空则根据 NOTABLE_BASE_ID 自动生成 alidocs 链接
NOTABLE_DOC_URL=
# 写表操作人 unionId（钉钉文档里可查）
NOTABLE_OPERATOR_UNION_ID=

# Trinity LLM
TRINITY_BASE_URL=https://api.trinitydesk.ai/v1
TRINITY_API_KEY=
LLM_MODEL=deepseek-v4-flash
# gpt-4o 等支持 json_object 的模型可设 true；deepseek-v4-flash 等请设 false
LLM_JSON_OBJECT=false

MESSAGE_LIMIT=50
MESSAGE_WINDOW_HOURS=2

# Stream / API
LOG_LEVEL=INFO
API_PORT=8788
INTERNAL_DRY_RUN_TOKEN=dev-only-change-me

# 权限未开通时可先关闭写表，仅在群内回复摘录结果
NOTABLE_WRITE_ENABLED=false
NOTABLE_ATTACH_IMAGES_ENABLED=true
NOTABLE_SCREENSHOT_FIELD=截图
CHAT_MESSAGE_READ_ENABLED=false
