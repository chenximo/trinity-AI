# 钉钉应用（开发者后台 → 凭证）
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# 仅允许这些群 conversationId，逗号分隔；留空则不限制
DINGTALK_ALLOWED_CONVERSATION_IDS=

# 钉钉多维表列顺序（列名须一致）：
# 创建时间 → 类型 → 标题 → 问题描述 → 图片和附件 → 所属模块 → 优先级 → 处理进度
# → 发现者 → 负责人 → 完成时间 → 会话摘要
# AI 写入：类型、标题、问题描述、所属模块、优先级、发现者、负责人、处理进度（待确认）、会话摘要、图片和附件
# PM 手填：完成时间；创建时间由钉钉自动填
# 优先级默认：Bug→P0，需求→P1，优化→P2（PM 可改）
NOTABLE_BASE_ID=
NOTABLE_SHEET_ID=
NOTABLE_SHEET_NAME=
# 可选；留空则根据 NOTABLE_BASE_ID 自动生成 alidocs 链接
NOTABLE_DOC_URL=
# 写表操作人 unionId（须能编辑多维表，当前：李玲）
NOTABLE_OPERATOR_UNION_ID=
# 负责人默认 unionId：崔宇光（Bug/优化）
NOTABLE_OWNER_DEFAULT_UNION_ID=
# 产品/需求负责人 unionId：李玲
NOTABLE_OWNER_PRODUCT_UNION_ID=
# 团队成员备查：任晓雷（发现者对照，可选）
NOTABLE_TEAM_RENXIAOLEI_UNION_ID=

# Trinity LLM
TRINITY_BASE_URL=https://api.trinitydesk.ai/v1
TRINITY_API_KEY=
LLM_MODEL=deepseek-v4-flash
# gpt-4o 等支持 json_object 的模型可设 true；deepseek-v4-flash 等请设 false
LLM_JSON_OBJECT=false

MESSAGE_LIMIT=50
MESSAGE_WINDOW_HOURS=2

# Stream / API
LOG_LEVEL=INFO
API_PORT=8788
INTERNAL_DRY_RUN_TOKEN=dev-only-change-me

# 权限未开通时可先关闭写表，仅在群内回复摘录结果
NOTABLE_WRITE_ENABLED=false
NOTABLE_ATTACH_IMAGES_ENABLED=true
# 附件列名（须为「附件」类型列）
NOTABLE_SCREENSHOT_FIELD=图片和附件
CHAT_MESSAGE_READ_ENABLED=false
